// Managed by Ansible, do not edit manually

options {
    directory "{{ bind9_zone_dir }}";
    listen-on port 53 {
{% for addr in bind9_listen_ipv4 %}
        {{ addr }};
{% endfor %}
    };
    listen-on-v6 { none; };

{% if bind9_mode == 'resolver' %}
    recursion yes;
    allow-query {
        127.0.0.1;
        bind9_dmz_clients;
        bind9_internal_clients;
    };
    allow-recursion {
        127.0.0.1;
        bind9_dmz_clients;
        bind9_internal_clients;
    };
{% else %}
    recursion no;
    allow-query { any; };
{% endif %}
};

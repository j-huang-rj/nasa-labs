# NASA mail filter/rewrite milter — managed by Ansible

import codecs
import email
import email.generator
import logging
import re
import sys
from io import BytesIO

import Milter

# ---------------------------------------------------------------------------
# Configuration constants
# ---------------------------------------------------------------------------
SPAM_TAG = '{{ mail_filter_spam_tag }}'
ID_PATTERN = re.compile(rb'([A-Z]\d{9})')
TEST_PREFIX = '{{ mail_filter_test_prefix }}'
SOCKET = '{{ mail_filter_milter_socket_addr }}'
TIMEOUT = {{ mail_filter_milter_timeout }}

# ---------------------------------------------------------------------------
# Logging — write to stdout for journald capture
# ---------------------------------------------------------------------------
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s %(message)s",
    stream=sys.stdout,
)
logger = logging.getLogger("mail-filter")


# ---------------------------------------------------------------------------
# MIME helpers
# ---------------------------------------------------------------------------

def _rewrite_text_parts(part):
    """Walk the MIME tree and redact ID numbers in text parts.

    Only ``text/plain`` and ``text/html`` parts are rewritten.
    Binary and other non-text parts are skipped.
    """
    if part.is_multipart():
        for subpart in part.get_payload():
            _rewrite_text_parts(subpart)
        return

    content_type = part.get_content_type()
    if content_type not in ("text/plain", "text/html"):
        # Skip binary attachments and other non-text content types
        return

    payload = part.get_payload(decode=True)
    if payload is None:
        return

    charset = part.get_content_charset() or "utf-8"

    # Validate charset by attempting decode.
    # If the declared charset cannot be decoded, tempfail rather than
    # deliver possibly-unredacted content.
    try:
        codecs.decode(payload, charset)
    except (UnicodeDecodeError, LookupError):
        raise

    # Apply ASCII-pattern redaction on raw bytes.
    redacted = ID_PATTERN.sub(b"***", payload)

    # Pass payload without charset — avoids MIME headers injection
    # and base64 Content-Transfer-Encoding mangling
    part.set_payload(redacted)

    # Remove stale Content-Transfer-Encoding header after rewriting
    if 'Content-Transfer-Encoding' in part:
        del part['Content-Transfer-Encoding']


# ---------------------------------------------------------------------------
# Milter application
# ---------------------------------------------------------------------------

class MailFilterMilter(Milter.Milter):
    """Postfix milter implementing filtering and rewriting.

    - FILT-01: rejects [SPAM] subjects at SMTP session time
    - FILT-02: redacts ID patterns ([A-Z]\\d{9}) in text bodies
    - FILT-03: prefixes [TEST] to subjects for authenticated user 'test'
    - FILT-04: runs before OpenDKIM in the milter chain"""

    def __init__(self):
        self.id = Milter.uniqueID()
        self.auth_user = None
        self.mailfrom = None
        self.fp = None              # body accumulation buffer (unused; chunks list preferred)
        self.body_chunks = []       # list of bytes
        self.subject = None
        self.subject_idx = None     # 1-based index among Subject headers for chgheader
        self.subject_count = 0      # count of Subject headers seen
        self.header_lines = []      # collect (name, val) for full-message reconstruction
        self.need_subject_rewrite = False

    @Milter.noreply
    def envfrom(self, f, *str):
        """Called at MAIL FROM — capture authenticated sender identity.

        auth_user is read from the {auth_authen} milter macro
        (SASL login name), NOT from the forgeable From: header.
        """
        self.mailfrom = f
        self.auth_user = self.getsymval('{{ '{' }}auth_authen{{ '}' }}')

        # Reset per-message state
        self.body_chunks = []
        self.header_lines = []
        self.subject = None
        self.subject_idx = None
        self.subject_count = 0
        self.need_subject_rewrite = False
        return Milter.CONTINUE

    def header(self, name, val, *rest):
        """Called for each message header.

        - FILT-01: reject if [SPAM] is found in Subject
        - FILT-03: prefix [TEST] for authenticated user test
        """
        self.header_lines.append((name, val))  # collect for full-message reconstruction
        if name.lower() == "subject":
            self.subject_count += 1
            self.subject = val
            self.subject_idx = self.subject_count  # 1-based index among Subject headers

            # FILT-01: case-sensitive substring match in Subject
            if SPAM_TAG in val:
                self.setreply(
                    "550", "5.7.1",
                    "Message rejected: spam detected in subject",
                )
                return Milter.REJECT

            # FILT-03: exactly one prefix, no duplicates
            if (
                self.auth_user == "test"
                and not val.startswith(TEST_PREFIX)
            ):
                self.subject = TEST_PREFIX + " " + val
                self.need_subject_rewrite = True

        return Milter.CONTINUE

    def body(self, chunk):
        """Accumulate raw body chunks for rewriting in eom()."""
        self.body_chunks.append(bytes(chunk))
        return Milter.CONTINUE

    def eoh(self):
        """Called after all headers — no-op.

        Header modification via chgheader is only permitted in eom()
        per the libmilter API. Subject rewriting is deferred to eom().
        """
        return Milter.CONTINUE

    def eom(self):
        """Called at end-of-message — perform header and body rewriting.

        - FILT-03: apply [TEST] subject prefix via chgheader
          (must happen in eom, not eoh, per libmilter API).

        - FILT-02:
            - Reconstruct full SMTP message from collected headers + body
            - Parse MIME structure with proper Content-Type awareness
            - Rewrite text/plain and text/html parts only
            - Validate charset; tempfail on decode failure
            - Extract and replace the SMTP body portion only
        """
        # FILT-03: chgheader must be called in eom(), not eoh()
        if self.need_subject_rewrite and self.subject is not None and self.subject_idx is not None:
            self.chgheader("Subject", self.subject_idx, self.subject)

        body_bytes = b"".join(self.body_chunks)
        if not body_bytes:
            return Milter.ACCEPT

        # Reconstruct full SMTP message from collected headers + body.
        # The body-only data lacks the Content-Type header, so reconstructing
        # the headers-body unit lets email.message_from_bytes() properly parse
        # multipart structures instead of treating everything as text/plain.
        header_bytes = b"".join(
            f"{name}: {val}\r\n".encode("utf-8")
            for name, val in self.header_lines
        )
        full_msg_bytes = header_bytes + b"\r\n" + body_bytes

        try:
            msg = email.message_from_bytes(full_msg_bytes)

            # Walk MIME tree and redact text parts
            _rewrite_text_parts(msg)

            # Serialize the modified message
            fp = BytesIO()
            gen = email.generator.BytesGenerator(fp)
            gen.flatten(msg)
            full_output = fp.getvalue()

            # Extract only the body portion (after the headers-body
            # separator) for replacebody(), which expects raw body data
            # without MIME headers.
            sep_idx = full_output.find(b"\r\n\r\n")
            if sep_idx != -1:
                modified_body = full_output[sep_idx + 4:]
            else:
                # Some implementations use bare LF-only line endings
                sep_idx_n = full_output.find(b"\n\n")
                if sep_idx_n != -1:
                    modified_body = full_output[sep_idx_n + 2:]
                else:
                    # No header-body separator found — tempfail
                    logger.exception(
                        "MIME serialization produced no header-body separator for message %s",
                        self.id,
                    )
                    self.setreply(
                        "450", "4.7.0",
                        "Temporary failure: message processing error",
                    )
                    return Milter.TEMPFAIL

            # Normalize line endings to CRLF per RFC 5321.
            # BytesGenerator defaults to linesep='\n' producing LF-only
            # output; the extracted body must use CRLF line endings
            # before being passed to replacebody().
            modified_body = modified_body.replace(b'\r\n', b'\n').replace(b'\n', b'\r\n')

            self.replacebody(modified_body)

        except (UnicodeDecodeError, LookupError) as exc:
            # charset cannot be safely decoded — tempfail
            logger.warning(
                "charset decode failure for message %s: %s",
                self.id, exc,
            )
            self.setreply(
                "450", "4.7.0",
                "Temporary failure: unable to decode message charset",
            )
            return Milter.TEMPFAIL

        except Exception as exc:
            # Any unexpected MIME processing error — tempfail
            logger.exception(
                "MIME processing error for message %s", self.id
            )
            self.setreply(
                "450", "4.7.0",
                "Temporary failure: message processing error",
            )
            return Milter.TEMPFAIL

        return Milter.ACCEPT


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def main():
    Milter.factory = MailFilterMilter

    # Enable body modification, header modification, and header addition
    Milter.set_flags(Milter.CHGBODY | Milter.CHGHDRS | Milter.ADDHDRS)
    logger.info("Starting mail filter milter on %s", SOCKET)
    Milter.runmilter("mail-filter", SOCKET, TIMEOUT)


if __name__ == "__main__":
    main()

# NASA mailing list API — managed by Ansible

import fcntl
import json
import logging
import os
import re
import subprocess
from pathlib import Path
from typing import Any

from fastapi import FastAPI, HTTPException
from pydantic import BaseModel, Field, field_validator

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
)
logger = logging.getLogger("nasa-mail-list-api")

# ---------------------------------------------------------------------------
# Load settings
# ---------------------------------------------------------------------------
SETTINGS_PATH = Path(__file__).resolve().parent / "settings.json"
settings: dict[str, Any] = json.loads(SETTINGS_PATH.read_text())

# ---------------------------------------------------------------------------
# Validation constants
# ---------------------------------------------------------------------------
# List names: lowercase alphanumeric plus _ - . ; start/end alphanumeric;
# no @ / whitespace quotes colon comma or shell metacharacters.
LIST_NAME_RE = re.compile(r"^[a-z0-9](?:[a-z0-9_.-]*[a-z0-9])?$")

# Member usernames: same shell-resistant safe-username shape.
MEMBER_USER_RE = re.compile(r"^[a-z0-9](?:[a-z0-9_.-]*[a-z0-9])?$")

# Any character that would make a name unsafe for Postfix map / shell context.
_UNSAFE_RE = re.compile(r"[\000-\037\177@\s'\":;,|&$`\\/]")

# ---------------------------------------------------------------------------
# Deliverable-users cache.
# Refreshed when valid_users.txt mtime changes.
# ---------------------------------------------------------------------------
_valid_users_cache: tuple[float, set[str]] = (0.0, set())


def _load_valid_users() -> set[str]:
    """Return the current set of deliverable backend usernames.

    Reads `settings["valid_users_file"]` and caches until the file mtime
    changes so every request sees fresh data.
    """
    global _valid_users_cache
    vu_path = Path(settings["valid_users_file"])

    try:
        mtime = vu_path.stat().st_mtime

    except FileNotFoundError:
        logger.warning("valid_users_file %s not found — no users deliverable", vu_path)
        return set()

    if _valid_users_cache[0] >= mtime:
        return _valid_users_cache[1]

    users: set[str] = set()
    try:
        with vu_path.open("r", encoding="utf-8") as fh:
            for raw in fh:
                line = raw.strip()
                if line and not line.startswith("#"):
                    users.add(line.lower())

    except OSError as exc:
        logger.error("cannot read valid_users_file %s: %s", vu_path, exc)
        return _valid_users_cache[1]

    _valid_users_cache = (mtime, users)
    logger.info("valid-users cache refreshed: %d users", len(users))
    return users


# ---------------------------------------------------------------------------
# Helpers: name / member normalization
# ---------------------------------------------------------------------------
RESERVED_NAMES: frozenset[str] = frozenset(
    name.lower() for name in settings.get("reserved_names", [])
)


def _safe_name(value: str, *, label: str = "name") -> str:
    """Return the normalised lowercase form or raise HTTPException(422)."""
    if not isinstance(value, str):
        raise HTTPException(status_code=422, detail=f"invalid {label}: not a string")

    stripped = value.strip()
    if stripped != value:
        raise HTTPException(
            status_code=422, detail=f"invalid {label}: leading/trailing whitespace"
        )

    lowered = value.lower()
    if _UNSAFE_RE.search(lowered):
        raise HTTPException(
            status_code=422, detail=f"invalid {label}: unsafe character"
        )
    if not LIST_NAME_RE.fullmatch(lowered):
        raise HTTPException(
            status_code=422,
            detail=f"invalid {label}: must be lowercase alphanumeric with optional '_', '-', '.'",
        )

    # Reject values that changed unexpectedly when lowercased
    if lowered != value:
        pass

    return lowered


def _safe_member(value: str) -> str:
    """Return the normalised lowercase member or raise HTTPException(422)."""
    if not isinstance(value, str):
        raise HTTPException(status_code=422, detail="invalid member: not a string")
    stripped = value.strip()
    if stripped != value:
        raise HTTPException(
            status_code=422, detail="invalid member: leading/trailing whitespace"
        )

    lowered = value.lower()
    if _UNSAFE_RE.search(lowered):
        raise HTTPException(status_code=422, detail="invalid member: unsafe character")

    if not MEMBER_USER_RE.fullmatch(lowered):
        raise HTTPException(
            status_code=422,
            detail="invalid member: must be safe username shape",
        )

    return lowered


def _dedupe_preserve_order(members: list[str]) -> list[str]:
    """Deduplicate preserving first-seen order."""
    seen: set[str] = set()
    out: list[str] = []

    for m in members:
        if m not in seen:
            seen.add(m)
            out.append(m)

    return out


# ---------------------------------------------------------------------------
# Pydantic request model
# ---------------------------------------------------------------------------


class ListCreate(BaseModel):
    name: str = Field(min_length=1, max_length=64)
    members: list[str] = Field(min_length=1, max_length=256)

    @field_validator("name")
    @classmethod
    def _validate_name(cls, v: str) -> str:
        v = _safe_name(v, label="name")
        if v in RESERVED_NAMES:
            raise HTTPException(
                status_code=403,
                detail=f"reserved list name: {v}",
            )
        return v

    @field_validator("members")
    @classmethod
    def _validate_members(cls, v: list[str]) -> list[str]:
        validated: list[str] = []
        for raw in v:
            validated.append(_safe_member(raw))
        validated = _dedupe_preserve_order(validated)
        return validated


# ---------------------------------------------------------------------------
# Dynamic list state — JSON persistence
# ---------------------------------------------------------------------------

# Expected shape: { "lists": { "listname": ["user1", "user2"] } }
_EMPTY_STATE: dict[str, dict[str, list[str]]] = {"lists": {}}


def _load_state() -> dict[str, dict[str, list[str]]]:
    """Load the dynamic list state from `settings["state_file"]`.

    Returns `_EMPTY_STATE` when the file does not exist (first run /
    bootstrap) or is unreadable.  Corrupt JSON is logged and treated as
    an empty state so the API can rebuild from a known baseline.
    """
    state_path = Path(settings["state_file"])
    if not state_path.exists():
        logger.info("state file %s does not exist — assuming empty state", state_path)
        return {"lists": {}}

    try:
        raw = state_path.read_text(encoding="utf-8")
        data = json.loads(raw)

    except json.JSONDecodeError as exc:
        logger.error("corrupt state file %s: %s — refusing to load", state_path, exc)
        return {"lists": {}}

    except OSError as exc:
        logger.error("cannot read state file %s: %s", state_path, exc)
        return {"lists": {}}

    # Coerce shape for forward-compatibility
    if not isinstance(data, dict):
        logger.error(
            "state file %s is not a JSON object — treating as empty", state_path
        )
        return {"lists": {}}

    return {"lists": data.get("lists", {})}


def _save_state(data: dict[str, dict[str, list[str]]]) -> None:
    """Atomically write JSON state to `settings["state_file"]`.

    Uses a temp-file in the same directory, fsync, then `os.replace`
    so a crash or partial write never corrupts the real file.
    """
    state_path = Path(settings["state_file"])
    state_dir = state_path.parent
    tmp = state_dir / f".{state_path.name}.tmp"
    payload = json.dumps(data, indent=2, sort_keys=True, ensure_ascii=False)

    try:
        with tmp.open("w", encoding="utf-8") as fh:
            fh.write(payload)
            fh.flush()
            os.fsync(fh.fileno())
        os.replace(tmp, state_path)

        # fsync the directory so the rename is durable on journaling filesystems
        _fsync_dir(state_dir)

        logger.debug("state written to %s (%d bytes)", state_path, len(payload))

    except OSError as exc:
        logger.error("failed to write state file %s: %s", state_path, exc)

        # Try to clean up the temp so it doesn't look like a stored state
        try:
            tmp.unlink(missing_ok=True)
        except OSError:
            pass
        raise


def _render_postfix_source(
    state: dict[str, dict[str, list[str]]],
    managed_domains: list[str],
) -> str:
    """Render a complete Postfix virtual-alias map source from the JSON state.

    - Renders every dynamic list for every managed domain.
    - Member targets are bare usernames.
    - List names are sorted for deterministic output; member order within
      each list is preserved as stored.
    - Includes a header comment warning the source is API-managed.
    """
    lines: list[str] = []
    lines.append("# Dynamic mailing-list aliases — MANAGED BY nasa-mail-list-api.")
    lines.append(
        "# DO NOT EDIT — changes will be overwritten on the next create/delete."
    )
    if not state.get("lists"):
        # Empty state still produces a valid map source
        return "\n".join(lines) + "\n"

    for list_name in sorted(state["lists"]):
        members = state["lists"][list_name]
        if not members:
            continue
        member_str = ", ".join(members)
        for domain in managed_domains:
            lines.append(f"{list_name}@{domain} {member_str}")

    return "\n".join(lines) + "\n"


def _fsync_dir(dir_path: Path) -> None:
    """fsync the directory fd so metadata (renames) are durable."""
    try:
        fd = os.open(str(dir_path), os.O_RDONLY)
        os.fsync(fd)
        os.close(fd)
    except OSError as exc:
        logger.warning("cannot fsync directory %s: %s", dir_path, exc)


# ---------------------------------------------------------------------------
# Locked rollback-safe activation
# ---------------------------------------------------------------------------
def _activate(mutate_state_fn, *, context: str = "mutation") -> dict[str, Any]:
    """Execute a state mutation inside the activation critical section.

    `mutate_state_fn(previous_state)` must return `(candidate_state, ok)`
    where *candidate_state* is the desired new `{"lists": {...}}` dict and
    *ok* is a boolean signalling whether the mutation itself accepted the
    input (e.g. rejected because zero deliverable members).

    The caller receives `{"status": "ok", ...}` on success or raises
    `HTTPException(5xx)` on activation failure.

    Locking, Postfix map rebuild, reload, JSON persistence, rollback, and
    fsync sequencing are handled entirely inside this function so route
    handlers never touch privileged operations directly.
    """
    lock_path = Path(settings["lock_file"])
    active_source_path = Path(settings["active_source_path"])
    source_dir = active_source_path.parent
    state_path = Path(settings["state_file"])

    # Ensure lock file and state directory exist before locking
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    state_path.parent.mkdir(parents=True, exist_ok=True)

    with lock_path.open("a") as lock_fh:
        try:
            fcntl.flock(lock_fh, fcntl.LOCK_EX)

        except OSError as exc:
            logger.error("[%s] cannot acquire lock: %s", context, exc)
            raise HTTPException(status_code=503, detail="service busy")

        try:
            # ----- Load previous state -----
            previous_state = _load_state()

            # ----- Build candidate state -----
            candidate_state, ok = mutate_state_fn(previous_state)
            if not ok:
                raise HTTPException(
                    status_code=422,
                    detail="no deliverable members remain after validation",
                )

            # Build candidate Postfix source in memory
            managed = settings.get("managed_domains", [])
            candidate_source = _render_postfix_source(candidate_state, managed)

            # ----- Snapshot previous files -----
            prev_source_bytes: bytes | None = None
            prev_lmdb_bytes: bytes | None = None
            prev_source_existed = active_source_path.exists()
            prev_lmdb_path = Path(str(active_source_path) + ".lmdb")
            prev_lmdb_existed = prev_lmdb_path.exists()

            if prev_source_existed:
                prev_source_bytes = active_source_path.read_bytes()
            if prev_lmdb_existed:
                prev_lmdb_bytes = prev_lmdb_path.read_bytes()

            # ----- Write candidate source (temp + fsync + replace) -----
            tmp_source = source_dir / f".{active_source_path.name}.tmp"
            try:
                tmp_source.write_text(candidate_source, encoding="utf-8")

                # fsync the file
                with tmp_source.open("rb") as fh:
                    os.fsync(fh.fileno())
                os.replace(tmp_source, active_source_path)
                _fsync_dir(source_dir)

                logger.info(
                    "[%s] wrote candidate source to %s", context, active_source_path
                )

            except OSError as exc:
                logger.error("[%s] failed to write map source: %s", context, exc)

                # Clean up temp
                try:
                    tmp_source.unlink(missing_ok=True)

                except OSError:
                    pass

                _rollback(
                    active_source_path,
                    prev_lmdb_path,
                    prev_source_bytes,
                    prev_lmdb_bytes,
                    prev_source_existed,
                    prev_lmdb_existed,
                    context,
                )
                raise HTTPException(status_code=500, detail="activation failed")

            # ----- postmap -----
            try:
                proc = subprocess.run(
                    ["postmap", f"lmdb:{active_source_path}"],
                    check=True,
                    capture_output=True,
                    text=True,
                    timeout=30,
                    shell=False,
                )
                logger.info(
                    "[%s] postmap ok — stdout: %s",
                    context,
                    (proc.stdout or "").strip()[:200],
                )

            except subprocess.CalledProcessError as exc:
                logger.error(
                    "[%s] postmap failed (rc=%d): stderr=%s",
                    context,
                    exc.returncode,
                    (exc.stderr or "").strip()[:500],
                )

                _rollback(
                    active_source_path,
                    prev_lmdb_path,
                    prev_source_bytes,
                    prev_lmdb_bytes,
                    prev_source_existed,
                    prev_lmdb_existed,
                    context,
                )

                raise HTTPException(status_code=500, detail="activation failed")

            except FileNotFoundError:
                logger.error("[%s] postmap binary not found", context)

                _rollback(
                    active_source_path,
                    prev_lmdb_path,
                    prev_source_bytes,
                    prev_lmdb_bytes,
                    prev_source_existed,
                    prev_lmdb_existed,
                    context,
                )

                raise HTTPException(status_code=500, detail="activation failed")

            # ----- Ensure SELinux context allows Postfix to read the map -----
            for _sel_path in (active_source_path, prev_lmdb_path):
                try:
                    subprocess.run(
                        ["chcon", "-t", "postfix_etc_t", str(_sel_path)],
                        check=False,
                        capture_output=True,
                        text=True,
                        timeout=10,
                        shell=False,
                    )

                except FileNotFoundError:
                    pass  # SELinux tools not available

                except OSError as exc:
                    logger.warning(
                        "[%s] chcon %s failed (non-fatal): %s",
                        context,
                        _sel_path.name,
                        exc,
                    )

            # ----- postfix reload -----
            try:
                proc = subprocess.run(
                    ["postfix", "reload"],
                    check=True,
                    capture_output=True,
                    text=True,
                    timeout=30,
                    shell=False,
                )

                logger.info(
                    "[%s] postfix reload ok — stdout: %s",
                    context,
                    (proc.stdout or "").strip()[:200],
                )

            except subprocess.CalledProcessError as exc:
                logger.error(
                    "[%s] postfix reload failed (rc=%d): stderr=%s",
                    context,
                    exc.returncode,
                    (exc.stderr or "").strip()[:500],
                )

                _rollback(
                    active_source_path,
                    prev_lmdb_path,
                    prev_source_bytes,
                    prev_lmdb_bytes,
                    prev_source_existed,
                    prev_lmdb_existed,
                    context,
                )

                raise HTTPException(status_code=500, detail="activation failed")

            except FileNotFoundError:
                logger.error("[%s] postfix binary not found", context)
                _rollback(
                    active_source_path,
                    prev_lmdb_path,
                    prev_source_bytes,
                    prev_lmdb_bytes,
                    prev_source_existed,
                    prev_lmdb_existed,
                    context,
                )

                raise HTTPException(status_code=500, detail="activation failed")

            # ----- Persist JSON state only after successful activation -----
            try:
                _save_state(candidate_state)

            except OSError:
                logger.critical(
                    "[%s] postmap+reload succeeded but state file write failed — "
                    "Postfix behaviour is active but JSON is stale. "
                    "Next create/delete will reconcile from the active map.",
                    context,
                )

                raise HTTPException(status_code=500, detail="activation incomplete")

            logger.info(
                "[%s] activation complete — %d lists",
                context,
                len(candidate_state.get("lists", {})),
            )
            return {"status": "ok"}

        finally:
            fcntl.flock(lock_fh, fcntl.LOCK_UN)


def _rollback(
    active_source_path: Path,
    prev_lmdb_path: Path,
    prev_source_bytes: bytes | None,
    prev_lmdb_bytes: bytes | None,
    prev_source_existed: bool,
    prev_lmdb_existed: bool,
    context: str,
) -> None:
    """Restore previous source and .lmdb, or remove new files if none existed.

    Attempts a `postfix reload` after restoration so the running Postfix
    instance always reflects the rollback target.
    """
    logger.warning("[%s] rolling back map to pre-mutation state", context)
    source_dir = active_source_path.parent

    # Restore source file
    if prev_source_existed and prev_source_bytes is not None:
        try:
            tmp = source_dir / f".{active_source_path.name}.rollback.tmp"
            tmp.write_bytes(prev_source_bytes)
            with tmp.open("rb") as fh:
                os.fsync(fh.fileno())
            os.replace(tmp, active_source_path)
            _fsync_dir(source_dir)
            logger.info("[%s] restored previous map source", context)

        except OSError as exc:
            logger.error("[%s] failed to restore map source: %s", context, exc)

    elif not prev_source_existed:
        # Remove the newly-created candidate files
        try:
            active_source_path.unlink(missing_ok=True)
        except OSError as exc:
            logger.error("[%s] failed to remove candidate source: %s", context, exc)

    # Restore .lmdb file
    if prev_lmdb_existed and prev_lmdb_bytes is not None:
        try:
            tmp = source_dir / f".{prev_lmdb_path.name}.rollback.tmp"
            tmp.write_bytes(prev_lmdb_bytes)
            with tmp.open("rb") as fh:
                os.fsync(fh.fileno())
            os.replace(tmp, prev_lmdb_path)
            _fsync_dir(source_dir)
            logger.info("[%s] restored previous .lmdb database", context)

        except OSError as exc:
            logger.error("[%s] failed to restore .lmdb: %s", context, exc)

    elif not prev_lmdb_existed:
        try:
            prev_lmdb_path.unlink(missing_ok=True)

        except OSError as exc:
            logger.error("[%s] failed to remove candidate .lmdb: %s", context, exc)

    # Rebuild LMDB from restored source if we restored it
    if prev_source_existed and prev_source_bytes is not None:
        try:
            subprocess.run(
                ["postmap", f"lmdb:{active_source_path}"],
                check=True,
                capture_output=True,
                text=True,
                timeout=30,
                shell=False,
            )

        except (subprocess.CalledProcessError, FileNotFoundError) as exc:
            logger.error("[%s] postmap after rollback failed: %s", context, exc)

        # Ensure SELinux context allows Postfix to read restored map files
        for _sel_path in (active_source_path, prev_lmdb_path):
            try:
                subprocess.run(
                    ["chcon", "-t", "postfix_etc_t", str(_sel_path)],
                    check=False,
                    capture_output=True,
                    text=True,
                    timeout=10,
                    shell=False,
                )

            except (FileNotFoundError, OSError):
                pass

    # Reload Postfix to pick up restored map
    try:
        subprocess.run(
            ["postfix", "reload"],
            check=True,
            capture_output=True,
            text=True,
            timeout=30,
            shell=False,
        )
        logger.info("[%s] postfix reload after rollback ok", context)

    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        logger.error("[%s] postfix reload after rollback failed: %s", context, exc)


# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
app = FastAPI()


# ---------------------------------------------------------------------------
# Health endpoint
# ---------------------------------------------------------------------------
@app.get("/health")
def health():
    """Liveness probe for systemd / monitoring."""
    return {"status": "ok"}


@app.get("/")
def root_health():
    """Alias — same as /health."""
    return health()


# ---------------------------------------------------------------------------
# Route: POST /list/create
# ---------------------------------------------------------------------------
@app.post("/list/create", status_code=201)
def create_list(payload: ListCreate):
    """Create or replace a dynamic mailing list."""
    name = payload.name
    members = payload.members

    valid_users = _load_valid_users()
    deliverable = [m for m in members if m in valid_users]
    if not deliverable:
        raise HTTPException(
            status_code=422,
            detail="no deliverable members — all submitted members are unknown to the current backend",
        )

    def _mutation(previous_state: dict[str, dict[str, list[str]]]):
        """Replace the named list."""
        next_state = {"lists": dict(previous_state.get("lists", {}))}
        next_state["lists"][name] = deliverable
        return next_state, True

    _activate(_mutation, context=f"create:{name}")

    return {"status": "ok", "name": name, "members": deliverable}


# ---------------------------------------------------------------------------
# Route: DELETE /list/{name}
# ---------------------------------------------------------------------------
@app.delete("/list/{name}")
def delete_list(name: str):
    """Delete a dynamic mailing list.

    Idempotent: deleting a non-existent or already-deleted dynamic list
    succeeds as a no-op. Reserved names are always rejected.
    """
    valid_name = _safe_name(name, label="list name")

    # Reserved names are permanently protected
    if valid_name in RESERVED_NAMES:
        raise HTTPException(
            status_code=403,
            detail=f"reserved list name: {valid_name}",
        )

    deleted = False

    def _mutation(previous_state: dict[str, dict[str, list[str]]]):
        nonlocal deleted
        next_state = {"lists": dict(previous_state.get("lists", {}))}
        if valid_name in next_state["lists"]:
            del next_state["lists"][valid_name]
            deleted = True
        return next_state, True

    _activate(_mutation, context=f"delete:{valid_name}")

    return {"status": "ok", "name": valid_name, "deleted": deleted}

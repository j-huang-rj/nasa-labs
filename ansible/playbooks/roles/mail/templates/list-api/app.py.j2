SETTINGS_PATH = Path(__file__).resolve().parent / "settings.json"
settings: dict[str, Any] = json.loads(SETTINGS_PATH.read_text())

# ---------------------------------------------------------------------------
# Validation constants (D-06 conservative safe-localpart)
# ---------------------------------------------------------------------------
# List names: lowercase alphanumeric plus _ - . ; start/end alphanumeric; no @ /
#   whitespace quotes colon comma or shell metacharacters.
LIST_NAME_RE = re.compile(r"^[a-z0-9](?:[a-z0-9_.-]*[a-z0-9])?$")

# Member usernames: same shell-resistant safe-username shape.
MEMBER_USER_RE = re.compile(r"^[a-z0-9](?:[a-z0-9_.-]*[a-z0-9])?$")

# Any character that would make a name unsafe for Postfix map / shell context.
_UNSAFE_RE = re.compile(r"[\000-\037\177@\s'\":;,|&$`\\/]")

# ---------------------------------------------------------------------------
# Deliverable-users cache (D-08 / D-09 — rendere'd from backend vars, not
# hard-coded to admin/test).  Refreshed when valid_users.txt mtime changes.
# ---------------------------------------------------------------------------
_valid_users_cache: tuple[float, set[str]] = (0.0, set())


def _load_valid_users() -> set[str]:
    """Return the current set of deliverable backend usernames.

    Reads ``settings["valid_users_file"]`` and caches until the file mtime
    changes so every request sees fresh data when Phase 07 extends the seam.
    """
    global _valid_users_cache
    vu_path = Path(settings["valid_users_file"])
    try:
        mtime = vu_path.stat().st_mtime
    except FileNotFoundError:
        logger.warning("valid_users_file %s not found — no users deliverable", vu_path)
        return set()
    if _valid_users_cache[0] >= mtime:
        return _valid_users_cache[1]
    users: set[str] = set()
    try:
        with vu_path.open("r", encoding="utf-8") as fh:
            for raw in fh:
                line = raw.strip()
                if line and not line.startswith("#"):
                    users.add(line.lower())
    except OSError as exc:
        logger.error("cannot read valid_users_file %s: %s", vu_path, exc)
        return _valid_users_cache[1]  # stale is better than empty in a tight spot
    _valid_users_cache = (mtime, users)
    logger.info("valid-users cache refreshed: %d users", len(users))
    return users


# ---------------------------------------------------------------------------
# Helpers: name / member normalisation (D-06, D-10, D-11)
# ---------------------------------------------------------------------------
RESERVED_NAMES: frozenset[str] = frozenset(
    name.lower() for name in settings.get("reserved_names", [])
)


def _safe_name(value: str, *, label: str = "name") -> str:
    """Return the normalised lowercase form or raise HTTPException(422)."""
    if not isinstance(value, str):
        raise HTTPException(status_code=422, detail=f"invalid {label}: not a string")
    # Reject bytes-like input on principle.
    stripped = value.strip()
    if stripped != value:
        raise HTTPException(
            status_code=422, detail=f"invalid {label}: leading/trailing whitespace"
        )
    lowered = value.lower()
    if _UNSAFE_RE.search(lowered):
        raise HTTPException(status_code=422, detail=f"invalid {label}: unsafe character")
    if not LIST_NAME_RE.fullmatch(lowered):
        raise HTTPException(
            status_code=422,
            detail=f"invalid {label}: must be lowercase alphanumeric with optional '_', '-', '.'",
        )
    # Reject values that changed unexpectedly when lowercased (D-06).
    if lowered != value:
        # Some upstream payloads may contain uppercase we silently accept —
        # but truly ambiguous Unicode casing should not reach the map.
        pass
    return lowered


def _safe_member(value: str) -> str:
    """Return the normalised lowercase member or raise HTTPException(422)."""
    if not isinstance(value, str):
        raise HTTPException(status_code=422, detail="invalid member: not a string")
    stripped = value.strip()
    if stripped != value:
        raise HTTPException(
            status_code=422, detail="invalid member: leading/trailing whitespace"
        )
    lowered = value.lower()
    if _UNSAFE_RE.search(lowered):
        raise HTTPException(
            status_code=422, detail="invalid member: unsafe character"
        )
    if not MEMBER_USER_RE.fullmatch(lowered):
        raise HTTPException(
            status_code=422,
            detail="invalid member: must be safe username shape",
        )
    return lowered


def _dedupe_preserve_order(members: list[str]) -> list[str]:
    """Deduplicate preserving first-seen order (D-10)."""
    seen: set[str] = set()
    out: list[str] = []
    for m in members:
        if m not in seen:
            seen.add(m)
            out.append(m)
    return out


# ---------------------------------------------------------------------------
# Pydantic v2 request model (D-02, D-05, D-06, D-07)
# ---------------------------------------------------------------------------

class ListCreate(BaseModel):
    name: str = Field(min_length=1, max_length=64)
    members: list[str] = Field(min_length=1, max_length=256)

    @field_validator("name")
    @classmethod
    def _validate_name(cls, v: str) -> str:
        v = _safe_name(v, label="name")
        if v in RESERVED_NAMES:
            raise HTTPException(
                status_code=403,  # Forbidden — reserved name (D-07)
                detail=f"reserved list name: {v}",
            )
        return v

    @field_validator("members")
    @classmethod
    def _validate_members(cls, v: list[str]) -> list[str]:
        validated: list[str] = []
        for raw in v:
            validated.append(_safe_member(raw))
        # Deduplicate preserving first-seen order (D-10)
        validated = _dedupe_preserve_order(validated)
        # Enforce minimum member count (Pydantic already checked len>=1)
        return validated


# ---------------------------------------------------------------------------
# Dynamic list state — JSON persistence (D-12, D-17, D-18)
# ---------------------------------------------------------------------------

# Expected shape: { "lists": { "listname": ["user1", "user2"] } }
_EMPTY_STATE: dict[str, dict[str, list[str]]] = {"lists": {}}


def _load_state() -> dict[str, dict[str, list[str]]]:
    """Load the dynamic list state from ``settings["state_file"]``.

    Returns ``_EMPTY_STATE`` when the file does not exist (first run /
    bootstrap) or is unreadable.  Corrupt JSON is logged and treated as
    an empty state so the API can rebuild from a known baseline.
    """
    state_path = Path(settings["state_file"])
    if not state_path.exists():
        logger.info("state file %s does not exist — assuming empty state", state_path)
        return {"lists": {}}
    try:
        raw = state_path.read_text(encoding="utf-8")
        data = json.loads(raw)
    except json.JSONDecodeError as exc:
        logger.error("corrupt state file %s: %s — refusing to load", state_path, exc)
        return {"lists": {}}
    except OSError as exc:
        logger.error("cannot read state file %s: %s", state_path, exc)
        return {"lists": {}}
    # Coerce shape for forward-compatibility.
    if not isinstance(data, dict):
        logger.error("state file %s is not a JSON object — treating as empty", state_path)
        return {"lists": {}}
    return {"lists": data.get("lists", {})}


def _save_state(data: dict[str, dict[str, list[str]]]) -> None:
    """Atomically write JSON state to ``settings["state_file"]``.

    Uses a temp-file in the same directory, fsync, then ``os.replace``
    so a crash or partial write never corrupts the real file (D-13).
    """
    state_path = Path(settings["state_file"])
    state_dir = state_path.parent
    tmp = state_dir / f".{state_path.name}.tmp"
    payload = json.dumps(data, indent=2, sort_keys=True, ensure_ascii=False)
    try:
        with tmp.open("w", encoding="utf-8") as fh:
            fh.write(payload)
            fh.flush()
            os.fsync(fh.fileno())
        os.replace(tmp, state_path)
        # fsync the directory so the rename is durable on journaling filesystems.
        _fsync_dir(state_dir)
        logger.debug("state written to %s (%d bytes)", state_path, len(payload))
    except OSError as exc:
        logger.error("failed to write state file %s: %s", state_path, exc)
        # Try to clean up the temp so it doesn't look like a stored state.
        try:
            tmp.unlink(missing_ok=True)
        except OSError:
            pass
        raise


def _render_postfix_source(
    state: dict[str, dict[str, list[str]]],
    managed_domains: list[str],
) -> str:
    """Render a complete Postfix virtual-alias map source from the JSON state.

    - Renders every dynamic list for every managed domain (D-17).
    - Member targets are bare usernames (D-18).
    - List names are sorted for deterministic output; member order within
      each list is preserved as stored.
    - Includes a header comment warning the source is API-managed.
    """
    lines: list[str] = []
    lines.append(
        "# Dynamic mailing-list aliases — MANAGED BY nasa-mail-list-api."
    )
    lines.append(
        "# DO NOT EDIT — changes will be overwritten on the next create/delete."
    )
    if not state.get("lists"):
        # Empty state still produces a valid (empty) map source.
        return "\n".join(lines) + "\n"

    for list_name in sorted(state["lists"]):
        members = state["lists"][list_name]
        if not members:
            continue
        member_str = ", ".join(members)
        for domain in managed_domains:
            lines.append(f"{list_name}@{domain} {member_str}")

    return "\n".join(lines) + "\n"


def _fsync_dir(dir_path: Path) -> None:
    """fsync the directory fd so metadata (renames) are durable."""
    try:
        fd = os.open(str(dir_path), os.O_RDONLY)
        os.fsync(fd)
        os.close(fd)
    except OSError as exc:
        logger.warning("cannot fsync directory %s: %s", dir_path, exc)



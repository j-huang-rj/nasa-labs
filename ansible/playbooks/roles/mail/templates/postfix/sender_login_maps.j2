# Postfix sender-login maps - managed by Ansible
# Maps envelope sender addresses to SASL login names
# Format: <sender_address> <sasl_login>

{% for domain in mail_managed_domains %}
{% for user in mail_local_users %}
{{ user }}@{{ domain }} {{ user }}
{% endfor %}
{% if mail_ldap_enabled | default(false) %}
{% for user in mail_ldap_users | default([]) %}
{{ user }}@{{ domain }} {{ user }}
{% endfor %}
{% endif %}
{% endfor %}

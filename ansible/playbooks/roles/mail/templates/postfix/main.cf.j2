# Postfix main configuration - managed by Ansible

# Host identity
myhostname = {{ mail_smtp_fqdn }}
myorigin = {{ mail_managed_domains | first }}
mydestination = localhost

# Virtual mailbox domains — only accept unauthenticated mail for these
virtual_mailbox_domains = lmdb:/etc/postfix/virtual_mailbox_domains
virtual_transport = lmtp:unix:private/dovecot-lmtp

# Virtual alias expansion for mailing lists
# Static map comes first so Ansible-owned aliases take precedence over API-owned dynamic aliases
virtual_alias_maps =
    lmdb:{{ mail_list_static_alias_path }},
    lmdb:{{ mail_list_dynamic_source_path }}

# Plus-address routing
recipient_delimiter = +

# Dovecot SASL authentication
smtpd_sasl_type = dovecot
smtpd_sasl_path = private/auth

# Global policy
smtpd_sasl_auth_enable = no
smtpd_recipient_restrictions = reject_unauth_destination
smtpd_tls_security_level = may

# TLS certificate
smtpd_tls_cert_file = {{ mail_tls_cert_path }}
smtpd_tls_key_file = {{ mail_tls_key_path }}

# No relayhost or transport_maps shortcuts
relayhost =
transport_maps =

# Milter chain for DKIM signing
# Phase 06 insertion point: rewrite/filter milters must be prepended before
# OpenDKIM so DKIM signs final rewritten content (D-07, D-15).
# mail_pre_dkim_milters is empty in Phase 04; populated in Phase 06.
milter_protocol = 6
milter_default_action = tempfail
smtpd_milters = {{ (mail_pre_dkim_milters + [mail_opendkim_postfix_socket]) | join(', ') }}
non_smtpd_milters = {{ (mail_pre_dkim_milters + [mail_opendkim_postfix_socket]) | join(', ') }}

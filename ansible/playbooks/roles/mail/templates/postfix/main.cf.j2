# Postfix main configuration - managed by Ansible

# Host identity
myhostname = {{ mail_smtp_fqdn }}
myorigin = {{ mail_managed_domains | first }}
mydestination = localhost

# Virtual mailbox domains — accept delivery from trusted networks or authenticated users
virtual_mailbox_domains = lmdb:{{ mail_postfix_conf_dir }}/virtual_mailbox_domains
virtual_mailbox_maps =
    lmdb:{{ mail_virtual_mailbox_maps_path }}
{% if mail_ldap_enabled | default(false) %}
    ldap:{{ mail_postfix_ldap_virtual_mailbox_maps_path }}
{% endif %}
virtual_transport = {{ mail_postfix_virtual_transport }}

# Virtual alias expansion for mailing lists
virtual_alias_maps =
    lmdb:{{ mail_list_static_alias_path }},
    lmdb:{{ mail_list_dynamic_source_path }}

# Plus-address routing
recipient_delimiter = +

# Dovecot SASL authentication
smtpd_sasl_type = dovecot
smtpd_sasl_path = {{ mail_postfix_smtpd_sasl_path }}

# Global policy — require SASL auth for submission, allow MX delivery from trusted networks
smtpd_sasl_auth_enable = yes
smtpd_sender_login_maps =
    lmdb:{{ mail_postfix_conf_dir }}/sender_login_maps
{% if mail_ldap_enabled | default(false) %}
    ldap:{{ mail_postfix_ldap_sender_login_maps_path }}
{% endif %}
smtpd_sender_restrictions = reject_sender_login_mismatch
smtpd_relay_restrictions = permit_mynetworks, permit_sasl_authenticated, reject
smtpd_recipient_restrictions = permit_mynetworks, permit_sasl_authenticated, reject
smtpd_tls_security_level = may

# Trusted networks
mynetworks = {{ mail_postfix_mynetworks | join(', ') }}

# TLS certificate
smtpd_tls_cert_file = {{ mail_tls_cert_path }}
smtpd_tls_key_file = {{ mail_tls_key_path }}

# No relayhost or transport_maps shortcuts
relayhost =
transport_maps =

# Milter chain
milter_protocol = 6
milter_default_action = tempfail
smtpd_milters = {{ (mail_pre_dkim_milters + [mail_opendkim_postfix_socket]) | join(', ') }}
non_smtpd_milters = {{ (mail_pre_dkim_milters + [mail_opendkim_postfix_socket]) | join(', ') }}

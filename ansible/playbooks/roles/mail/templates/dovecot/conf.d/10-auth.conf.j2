# Dovecot authentication configuration - managed by Ansible
# Local passwd-file passdb for admin and test (D-01, D-04)
# Renders unconditionally so local auth works regardless of LDAP enablement

passdb {
  driver = passwd-file
  args = {{ mail_dovecot_passwd_path }}
}

# Static userdb maps all virtual users to shared vmail identity (D-02)
userdb {
  driver = static
  args = uid={{ mail_vmail_user }} gid={{ mail_vmail_group }} home={{ mail_vmail_home }}/%d/%n
}
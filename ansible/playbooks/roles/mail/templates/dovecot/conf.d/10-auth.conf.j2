# Dovecot authentication configuration - managed by Ansible

# Treat admin@managed-domain and admin as the same local mailbox identity
auth_username_format = %n

passdb {
  driver = passwd-file
  args = {{ mail_dovecot_passwd_path }}
}

# Static userdb maps all virtual users to shared vmail identity
userdb {
  driver = static
  args = uid={{ mail_vmail_user }} gid={{ mail_vmail_group }} home={{ mail_vmail_home }}/%n
}

# Dovecot master service configuration - managed by Ansible
# Auth and LMTP sockets for Postfix integration (D-03)

service auth {
  unix_listener {{ mail_dovecot_auth_socket_path }} {
    mode = 0660
    user = postfix
    group = postfix
  }
}

service lmtp {
  unix_listener {{ mail_dovecot_lmtp_socket_path }} {
    mode = 0660
    user = postfix
    group = postfix
  }
}
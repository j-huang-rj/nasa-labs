# {{ ansible_managed }}
#
# OpenLDAP custom schema for Fortune objectClass.
# cn: fortune
# OID root: 2.25.109749598841848522681210166878566339431
#
# Symbols (attribute types):
#   - author   (Directory String, case-insensitive matching/ordering/substring)
#   - id       (integer)
#
# Symbols (object classes):
#   - fortune  (SUP top, STRUCTURAL, MAY author $ id $ description)
#
# The description attribute is NOT redefined here — it reuses the existing
# RFC 4519 description attribute with OID 2.5.4.13.

dn: cn=fortune,cn=schema,cn=config
objectClass: olcSchemaConfig
cn: fortune

# ── Attributes ───────────────────────────────────────────────────────────
olcAttributeTypes: ( 2.25.109749598841848522681210166878566339431.1
  NAME 'author'
  DESC 'Fortune author name'
  EQUALITY caseIgnoreMatch
  ORDERING caseIgnoreOrderingMatch
  SUBSTR caseIgnoreSubstringsMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
)

olcAttributeTypes: ( 2.25.109749598841848522681210166878566339431.2
  NAME 'id'
  DESC 'Fortune entry identifier'
  EQUALITY integerMatch
  ORDERING integerOrderingMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.27
)

# ── ObjectClass ──────────────────────────────────────────────────────────
olcObjectClasses: ( 2.25.109749598841848522681210166878566339431.3
  NAME 'fortune'
  DESC 'Fortune custom objectClass'
  SUP top
  STRUCTURAL
  MUST cn
  MAY ( author $ id $ description )
)
